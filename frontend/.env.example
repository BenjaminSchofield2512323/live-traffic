# Copy to .env.local and adjust. Vite loads .env*, not this file.

# --- Dev: two backends ---
# 1) Go API MUST be running on :8080 (serves /api, /artifacts, /healthz). Example:
#    cd ../backend && go run ./cmd/api
#    Or from repo root: make dev-backend
# 2) Python detector on :8090 is separate (YOLO). It does NOT fix "proxy error" for /api.
#    If Vite prints ECONNREFUSED for /api/..., (1) is missing or wrong port.

# Production / `vite build`: browser needs the real API origin.
# VITE_API_BASE_URL=http://localhost:8080

# Dev (`npm run dev`): by default the app uses same-origin /api and vite.config.js
# proxies to http://127.0.0.1:8080. You usually do NOT need VITE_API_BASE_URL.

# To bypass the proxy and set the API URL explicitly in dev (e.g. staging):
# VITE_DEV_DIRECT_API=1
# VITE_API_BASE_URL=https://your-api.example.com

# Optional: change where the dev server proxies /api (default :8080)
# VITE_API_PROXY_TARGET=http://localhost:8080
